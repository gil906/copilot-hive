# ══════════════════════════════════════════════════════════════════════
#  Copilot Hive — Crontab Schedule
#  Install with: crontab crontab.example
#  Or merge into existing: crontab -e
# ══════════════════════════════════════════════════════════════════════

# Pipeline dispatcher — runs every minute, chains agents automatically
* * * * * /opt/copilot-hive/copilot-dispatcher.sh >> /opt/copilot-hive/copilot-dispatcher.log 2>&1

# ── Research Agents (Specialists) — every hour, staggered ────────────
0  * * * * /opt/copilot-hive/copilot-designer-web.sh >> /opt/copilot-hive/copilot-designer-web.log 2>&1
5  * * * * /opt/copilot-hive/copilot-designer-portal.sh >> /opt/copilot-hive/copilot-designer-portal.log 2>&1
10 * * * * /opt/copilot-hive/copilot-architect-api.sh >> /opt/copilot-hive/copilot-architect-api.log 2>&1

# ── Research Agents (Strategic) — every 2 hours ──────────────────────
15 */2 * * * /opt/copilot-hive/copilot-radical.sh >> /opt/copilot-hive/copilot-radical.log 2>&1
20 */2 * * * /opt/copilot-hive/copilot-lawyer.sh >> /opt/copilot-hive/copilot-lawyer.log 2>&1
25 */2 * * * /opt/copilot-hive/copilot-compliance.sh >> /opt/copilot-hive/copilot-compliance.log 2>&1

# ── Reporter — daily + weekly summaries ──────────────────────────────
0 18 * * *   /opt/copilot-hive/copilot-reporter.sh daily >> /opt/copilot-hive/copilot-reporter.log 2>&1
0 18 * * 0   /opt/copilot-hive/copilot-reporter.sh weekly >> /opt/copilot-hive/copilot-reporter.log 2>&1

# ── Security & Testing — daily at midnight ───────────────────────────
0  0 * * *   /opt/copilot-hive/copilot-gitguardian.sh >> /opt/copilot-hive/copilot-gitguardian.log 2>&1
30 0 * * *   /opt/copilot-hive/copilot-regressiontest.sh >> /opt/copilot-hive/copilot-regressiontest.log 2>&1
